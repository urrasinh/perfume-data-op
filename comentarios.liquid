{%- comment -%}
  Muestra comentarios del SKU consumiendo el endpoint privado que devuelve HTML.
  Configura API_BASE con tu dominio Netlify y (opcional) TOKEN_SALT si lo activas en el servidor.
{%- endcomment -%}

{%- assign API_BASE = 'https://monumental-pudding-cc51a5.netlify.app' -%}
{%- assign TOKEN_SALT = '' -%}
{%- assign sku = product.selected_or_first_available_variant.sku -%}

{%- if TOKEN_SALT != '' -%}
  {%- assign hour_bucket = 'now' | date: '%s' | divided_by: 3600 -%}
  {%- assign token_input = sku | append: ':' | append: hour_bucket -%}
  {%- assign token = token_input | hmac_sha256: TOKEN_SALT -%}
{%- endif -%}

<div id="comentarios-container"
     data-sku="{{ sku }}"
     data-api="{{ API_BASE }}/api/comentarios"
     {% if token %}data-token="{{ token }}"{% endif %}
     style="display: none;">
</div>

<style>
  :root {
    --com-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --com-card: #fafafa;
    --com-border: #ececec;
    --com-text: #1a1a1a;
    --com-muted: #888;
    --com-accent: #111;
  }
  #comentarios-container {
    width: 100%;
    max-width: 780px;
    margin: 2.5rem 0;
    font-family: var(--com-font);
    color: var(--com-text);
  }
  .comentarios-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--com-border);
  }
  .comentarios-title {
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    color: var(--com-accent);
  }
  .comentarios-count { font-size: 0.8rem; color: var(--com-muted); font-weight: 500; }
  #comentarios-list { display: flex; flex-direction: column; gap: 14px; }
  .comentario-card {
    background: var(--com-card);
    border: 1px solid var(--com-border);
    border-radius: 14px;
    padding: 18px 20px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    opacity: 0;
    transform: translateY(8px);
    animation: comFadeInUp 0.45s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  .comentario-card:hover {
    border-color: #d8d8d8;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
    transform: translateY(-1px);
  }
  .comentario-card.hidden { display: none; }
  @keyframes comFadeInUp { to { opacity: 1; transform: translateY(0); } }
  .comentario-top { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .comentario-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 0.85rem; font-weight: 600;
    text-transform: uppercase; flex-shrink: 0;
  }
  .comentario-meta { display: flex; flex-direction: column; min-width: 0; flex: 1; }
  .comentario-usuario {
    font-size: 0.9rem; font-weight: 600; color: var(--com-text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .comentario-fecha { font-size: 0.75rem; color: var(--com-muted); margin-top: 2px; }
  .comentario-texto {
    font-size: 0.92rem; line-height: 1.55; color: #333;
    margin: 0; white-space: pre-line;
  }
  .comentarios-toggle {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    width: 100%; margin-top: 16px; padding: 12px 16px;
    background: transparent; border: 1px solid var(--com-border);
    border-radius: 12px; font-family: inherit; font-size: 0.82rem;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--com-accent); cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .comentarios-toggle:hover { background: #f5f5f5; border-color: #d0d0d0; }
  .comentarios-toggle .toggle-icon { transition: transform 0.3s ease; }
  .comentarios-toggle.expanded .toggle-icon { transform: rotate(180deg); }
  @media (max-width: 480px) {
    .comentario-card { padding: 16px; border-radius: 12px; }
    .comentario-avatar { width: 34px; height: 34px; font-size: 0.8rem; }
    .comentario-texto { font-size: 0.88rem; }
  }
</style>

<script>
  (function () {
    const container = document.getElementById('comentarios-container');
    if (!container) return;

    const sku = container.dataset.sku;
    const api = container.dataset.api;
    const token = container.dataset.token;
    if (!sku || !api) return;

    const url = new URL(api);
    url.searchParams.set('sku', sku);
    if (token) url.searchParams.set('t', token);

    fetch(url.toString(), { credentials: 'omit', mode: 'cors' })
      .then(function (r) { return r.ok ? r.text() : null; })
      .then(function (html) {
        if (!html) return;
        container.innerHTML = html;
        container.style.display = 'block';

        const toggle = container.querySelector('#comentarios-toggle');
        if (!toggle) return;
        const list = container.querySelector('#comentarios-list');
        const toggleText = toggle.querySelector('.toggle-text');

        toggle.addEventListener('click', function () {
          const expanded = toggle.classList.toggle('expanded');
          const targets = list.querySelectorAll('.comentario-card.hidden, .comentario-card.revealed');
          targets.forEach(function (card, i) {
            if (expanded) {
              card.classList.remove('hidden');
              card.classList.add('revealed');
              card.style.animation = 'none';
              void card.offsetWidth;
              card.style.animationDelay = (i * 60) + 'ms';
              card.style.animation = '';
            } else {
              card.classList.add('hidden');
              card.classList.remove('revealed');
            }
          });
          toggleText.textContent = expanded ? 'Ver menos' : 'Ver más opiniones';
        });
      })
      .catch(function () { /* silencioso */ });
  })();
</script>
