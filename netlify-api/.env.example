# Dominios permitidos (separados por coma). Origin/Referer debe coincidir con alguno.
# Incluye tu dominio Shopify permanente y los dominios personalizados que uses.
ALLOWED_ORIGINS=https://tu-tienda.myshopify.com,https://www.tudominio.com

# Salt publico para el token del Liquid. No es un secreto, pero debe coincidir en el Liquid.
TOKEN_SALT=cambia-esto-por-algo-unico-de-tu-tienda

# Rate limit por IP (requests por ventana de 60s). 0 = sin limite.
RATE_LIMIT_PER_MIN=120
